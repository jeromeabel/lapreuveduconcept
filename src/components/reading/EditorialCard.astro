---
import type { CollectionEntry } from 'astro:content';
import ComicImage from '../ComicImage.astro';
import VoteButton from '../VoteButton.astro';
import ShareActions from '../ShareActions.astro';

interface Props {
	comic: CollectionEntry<'comics'>;
	index: number;
	total: number;
	eager?: boolean;
}

const { comic, index, total, eager = false } = Astro.props;
---

<article
	class="beat"
	data-index={index + 1}
	data-label={`${comic.id} — ${comic.data.title}`}
>
	<div class="beat-inner">
		<div class="beat-num">Strip {comic.id}</div>
		<div class="panels">
			{comic.data.pages.map((page, i) => (
				<div class="panel" data-p>
					<ComicImage
						src={page}
						alt={`${comic.data.alt} — page ${i + 1}`}
						eager={eager && i < 2}
					/>
				</div>
			))}
		</div>
		<div class="swipe-indicator">
			{comic.data.pages.map((_, i) => (
				<div class:list={['swipe-dot', { active: i === 0 }]} />
			))}
		</div>
		<div class="caption">
			<span class="caption-id">{comic.id}</span>
			<a href={`/${comic.id}`} class="caption-title">{comic.data.title}</a>
		</div>
		<div class="beat-actions">
			<VoteButton slug={comic.id} />
			<ShareActions slug={comic.id} title={comic.data.title} />
		</div>
	</div>
</article>

<style>
	.beat {
		min-height: 100vh;
		scroll-snap-align: center;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: 4rem 2rem;
		position: relative;
	}

	/* Baseline reveal (JS fallback) */
	.beat-inner {
		opacity: 0;
		transform: translateY(40px);
		transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
		max-width: 900px;
	}
	:global(.beat.is-visible) .beat-inner {
		opacity: 1;
		transform: translateY(0);
	}

	/* Enhanced: CSS scroll-driven reveal */
	@supports (animation-timeline: view()) {
		.beat-inner {
			opacity: 1;
			transform: none;
			transition: none;
			animation: beat-reveal linear both;
			animation-timeline: view();
			animation-range: entry 5% entry 60%;
		}
		@keyframes beat-reveal {
			from { opacity: 0; transform: translateY(50px) scale(0.97); filter: blur(3px); }
			to   { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
		}
	}

	.beat-num {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.5rem;
		opacity: 0.8;
	}

	/* Panels container */
	.panels {
		display: flex;
		gap: 1rem;
		justify-content: center;
		width: 100%;
	}

	@media (max-width: 640px) {
		.beat { padding: 3rem 0.5rem; }
		.panels {
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			padding: 0 1rem 1rem;
			gap: 0.8rem;
			justify-content: flex-start;
			scrollbar-width: none;
		}
		.panels::-webkit-scrollbar { display: none; }
		.panels .panel {
			scroll-snap-align: center;
			flex-shrink: 0;
			width: 78vw;
		}
	}

	/* Individual panel */
	.panel {
		width: clamp(180px, 24vw, 420px);
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 4px;
		position: relative;
		overflow: hidden;
		cursor: pointer;
		transition:
			transform 0.4s var(--ease-out-expo),
			border-color 0.3s ease,
			box-shadow 0.4s var(--ease-out-expo);
	}
	.panel:hover {
		transform: translateY(-6px) scale(1.02);
		border-color: var(--border-hover);
		box-shadow: var(--panel-shadow);
	}

	/* Staggered reveal per panel */
	.panel:nth-child(1) { --stagger: 0ms; }
	.panel:nth-child(2) { --stagger: 120ms; }
	.panel:nth-child(3) { --stagger: 240ms; }

	:global(.beat) .panel {
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 0.7s var(--ease-out-expo) var(--stagger),
			transform 0.7s var(--ease-out-expo) var(--stagger);
	}
	:global(.beat.is-visible) .panel {
		opacity: 1;
		transform: translateY(0);
	}
	:global(.beat.is-visible) .panel:hover {
		transform: translateY(-6px) scale(1.02);
	}

	/* Enhanced: CSS scroll-driven clip-path reveal */
	@supports (animation-timeline: view()) {
		:global(.beat) .panel {
			opacity: 1;
			transform: none;
			animation: panel-clip-reveal linear both;
			animation-timeline: view();
			animation-range: entry 10% cover 35%;
		}
		.panel:nth-child(1) { animation-delay: 0ms; }
		.panel:nth-child(2) { animation-delay: 80ms; }
		.panel:nth-child(3) { animation-delay: 160ms; }

		@keyframes panel-clip-reveal {
			from { opacity: 0; clip-path: inset(8% 12% 8% 12%); transform: scale(0.92); }
			to   { opacity: 1; clip-path: inset(0% 0% 0% 0%); transform: scale(1); }
		}
	}

	/* Caption */
	.caption {
		margin-top: 1.6rem;
		text-align: center;
	}
	.caption-id {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		color: var(--text-dim);
		display: block;
		margin-bottom: 0.3rem;
	}
	.caption-title {
		font-size: clamp(1.1rem, 2.5vw, 1.6rem);
		font-weight: 700;
		letter-spacing: -0.01em;
		text-decoration: none;
		color: var(--text);
	}
	.caption-title:hover {
		color: var(--accent);
	}

	.beat-actions {
		margin-top: 0.6rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	/* Mobile swipe indicator dots */
	.swipe-indicator {
		display: none;
		gap: 6px;
		margin-top: 0.8rem;
		justify-content: center;
	}
	@media (max-width: 640px) {
		.swipe-indicator { display: flex; }
	}
	.swipe-dot {
		width: 5px; height: 5px;
		border-radius: 50%;
		background: var(--text-dim);
		transition: background 0.3s;
	}
	.swipe-dot.active { background: var(--accent); }
</style>
