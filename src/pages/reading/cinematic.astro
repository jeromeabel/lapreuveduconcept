---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CinematicCard from '../../components/reading/CinematicCard.astro';

const comics = await getCollection('comics');
const sortedComics = comics.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalSections = sortedComics.length + 1; // +1 for title screen
---

<Layout title="Reading — Cinematic" earlyVoteIds={sortedComics.map(c => c.id)}>
	<!-- Progress bar -->
	<div class="progress-bar" id="progress"></div>

	<!-- Tap zone flash overlays -->
	<div class="tap-flash left" id="tapLeft"></div>
	<div class="tap-flash right" id="tapRight"></div>

	<!-- Navigation dots -->
	<nav class="nav-dots" id="navDots" aria-label="Navigation rapide"></nav>

	<!-- Shortcut hint -->
	<div class="shortcut-hint" id="shortcutHint">↑ ↓ · ← → · espace · clic gauche / droit</div>

	<!-- Main scroll container -->
	<div class="comic-wall" id="scroller">
		<!-- Title screen -->
		<section class="title-screen" data-index="0">
			<p class="subtitle">Prototype UX</p>
			<h1>Le Concept<br>de la Preuve</h1>
			<p class="subtitle">par Jérôme Abel</p>
			<div class="scroll-hint">
				scroll ou clic pour commencer
				<span>↓</span>
			</div>
		</section>

		{sortedComics.map((comic, index) => (
			<CinematicCard
				comic={comic}
				index={index}
				total={sortedComics.length}
				eager={index === 0}
			/>
		))}
	</div>
</Layout>

<style>
	/* ─── Color palette (warm paper) ─── */
	:root {
		--bg-warm: #faf9f6;
		--ink: #1a1a1a;
		--muted: #999;
		--accent: #c43b2a;
		--panel-border: #d4d0c8;
	}

	/* ─── Scroll container ─── */
	.comic-wall {
		height: 100vh;
		width: 100vw;
		overflow-y: scroll;
		scroll-snap-type: y mandatory;
		scrollbar-width: none;
		background: var(--bg-warm);
		/* Break out of the page-shell */
		position: fixed;
		inset: 0;
		z-index: 10;
	}
	.comic-wall::-webkit-scrollbar { display: none; }

	/* ─── Title screen ─── */
	.title-screen {
		height: 100vh;
		scroll-snap-align: center;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 1.2rem;
		opacity: 0;
		animation: fadeIn 1.2s ease forwards;
	}
	.title-screen h1 {
		font-size: clamp(2rem, 5vw, 3.6rem);
		letter-spacing: -0.02em;
		text-align: center;
		line-height: 1.15;
		font-weight: 700;
	}
	.subtitle {
		font-size: 0.85rem;
		color: var(--muted);
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}
	.scroll-hint {
		margin-top: 3rem;
		font-size: 0.75rem;
		color: var(--muted);
		text-align: center;
		animation: pulse 2.5s ease-in-out infinite;
	}
	.scroll-hint span {
		display: block;
		margin-top: 0.4rem;
		font-size: 1.2rem;
		animation: bounce 2s ease-in-out infinite;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(20px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes pulse {
		0%, 100% { opacity: 0.5; }
		50%      { opacity: 1; }
	}
	@keyframes bounce {
		0%, 100% { transform: translateY(0); }
		50%      { transform: translateY(6px); }
	}

	/* ─── Progress bar ─── */
	.progress-bar {
		position: fixed;
		top: 0;
		left: 0;
		height: 2px;
		background: var(--accent);
		width: 0%;
		z-index: 200;
		transition: width 0.2s ease-out;
	}

	/* ─── Navigation dots ─── */
	.nav-dots {
		position: fixed;
		right: 1.2rem;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		gap: 8px;
		z-index: 200;
	}

	/* ─── Tap zone flash overlays ─── */
	.tap-flash {
		position: fixed;
		top: 0;
		height: 100vh;
		width: 50%;
		pointer-events: none;
		z-index: 150;
		opacity: 0;
	}
	.tap-flash.left  { left: 0; }
	.tap-flash.right { right: 0; }

	/* ─── Shortcut hint ─── */
	.shortcut-hint {
		position: fixed;
		bottom: 1.2rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.65rem;
		color: var(--muted);
		letter-spacing: 0.1em;
		opacity: 0.6;
		transition: opacity 0.5s ease;
		pointer-events: none;
		z-index: 200;
		white-space: nowrap;
	}

	@media (max-width: 600px) {
		.nav-dots { display: none; }
	}

	@media (prefers-reduced-motion: reduce) {
		.comic-wall {
			scroll-snap-type: y proximity;
		}
		.title-screen {
			animation: none;
			opacity: 1;
		}
	}
</style>

<script>
	const scroller = document.getElementById('scroller');
	const sections = [...document.querySelectorAll<HTMLElement>('[data-index]')];
	const progressBar = document.getElementById('progress')!;
	const navDotsContainer = document.getElementById('navDots')!;
	const shortcutHint = document.getElementById('shortcutHint')!;
	const tapLeft = document.getElementById('tapLeft')!;
	const tapRight = document.getElementById('tapRight')!;

	let currentIndex = 0;
	let interactionCount = 0;

	// ─── Build nav dots ───
	sections.forEach((_, i) => {
		const dot = document.createElement('button');
		dot.className = 'cine-dot';
		dot.setAttribute('aria-label', `Section ${i}`);
		dot.addEventListener('click', (e) => {
			e.stopPropagation();
			scrollToIndex(i);
		});
		navDotsContainer.appendChild(dot);
	});
	const dots = [...navDotsContainer.querySelectorAll<HTMLElement>('.cine-dot')];

	// ─── Style dots via JS (avoids global CSS leaking) ───
	const dotStyles = `
		.cine-dot {
			width: 6px; height: 6px; border-radius: 50%;
			background: #d4d0c8; border: none; cursor: pointer;
			transition: all 0.3s ease; padding: 0;
		}
		.cine-dot:hover { background: #999; transform: scale(1.5); }
		.cine-dot.active { background: #c43b2a; transform: scale(1.4); }
		.tap-flash.show { animation: flashFade 0.3s ease-out; }
		@keyframes flashFade {
			0%   { opacity: 0.06; background: #1a1a1a; }
			100% { opacity: 0; }
		}
		.shortcut-hint.is-hidden { opacity: 0; }
	`;
	const styleEl = document.createElement('style');
	styleEl.textContent = dotStyles;
	document.head.appendChild(styleEl);

	// ─── Scroll to section ───
	const scrollToIndex = (index: number) => {
		const clamped = Math.max(0, Math.min(index, sections.length - 1));
		sections[clamped].scrollIntoView({ behavior: 'smooth', block: 'center' });
		currentIndex = clamped;
		updateUI();
	};

	// ─── Update progress & dots ───
	const updateUI = () => {
		const pct = (currentIndex / (sections.length - 1)) * 100;
		progressBar.style.width = `${pct}%`;

		dots.forEach((d, i) => d.classList.toggle('active', i === currentIndex));

		interactionCount++;
		if (interactionCount > 3) {
			shortcutHint.classList.add('is-hidden');
		}
	};

	// ─── Intersection Observer for reveal animation ───
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					const idx = parseInt((entry.target as HTMLElement).dataset.index ?? '', 10);
					if (!isNaN(idx)) {
						currentIndex = idx;
						updateUI();
					}
				}
			}
		},
		{ root: scroller, threshold: 0.35 },
	);
	sections.forEach((s) => observer.observe(s));

	// ─── Keyboard navigation ───
	document.addEventListener('keydown', (e) => {
		const next = ['ArrowDown', 'ArrowRight', ' '];
		const prev = ['ArrowUp', 'ArrowLeft'];

		if (next.includes(e.key)) {
			e.preventDefault();
			scrollToIndex(currentIndex + 1);
		} else if (prev.includes(e.key)) {
			e.preventDefault();
			scrollToIndex(currentIndex - 1);
		}
	});

	// ─── Tap / click navigation with flash ───
	const flash = (el: HTMLElement) => {
		el.classList.remove('show');
		void el.offsetWidth; // reflow to restart animation
		el.classList.add('show');
	};

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (target.closest('.nav-dots') || target.closest('a') || target.closest('button')) return;

		const isRight = e.clientX > window.innerWidth / 2;
		if (isRight) {
			flash(tapRight);
			scrollToIndex(currentIndex + 1);
		} else {
			flash(tapLeft);
			scrollToIndex(currentIndex - 1);
		}
	});

	// ─── Init ───
	updateUI();
	document.querySelector('.title-screen')?.classList.add('is-visible');
</script>
