---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import EditorialCard from '../../components/reading/EditorialCard.astro';

const comics = await getCollection('comics');
const sortedComics = comics.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalSections = sortedComics.length + 1;
---

<html lang="fr" data-theme="dark">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Le Concept de la Preuve — Editorial</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Fira+Code:wght@300;400;500&family=Inconsolata:wght@400;600&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>
	<!-- Fixed UI elements -->
	<div class="progress" id="progress"></div>
	<div class="mist-top"></div>
	<div class="mist-bottom"></div>
	<div class="ripple" id="ripple"></div>

	<div class="controls">
		<a class="logo" href="/">LCDLP</a>
		<div class="controls-right">
			<button class="ctrl-btn" id="themeToggle" aria-label="Changer le thème">
				<svg id="themeIcon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/></svg>
			</button>
			<button class="ctrl-btn" id="shortcutsBtn" aria-label="Raccourcis clavier">
				<span>?</span>
			</button>
			<a class="ctrl-btn" href="/reading/" aria-label="Retour aux prototypes">
				<svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
			</a>
		</div>
	</div>

	<nav class="nav-rail" id="navRail" aria-label="Navigation rapide"></nav>
	<div class="hint-bar" id="hintBar">↑ ↓ · clic · espace · T thème · ? aide</div>
	<div class="strip-counter" id="stripCounter">— / —</div>

	<!-- Shortcuts overlay -->
	<div class="shortcuts-overlay" id="shortcutsOverlay">
		<div class="shortcuts-box">
			<h3>Raccourcis clavier</h3>
			<div class="shortcut-row">
				<span class="label">Strip suivant</span>
				<span class="keys"><span class="kbd">↓</span><span class="kbd">→</span><span class="kbd">Espace</span></span>
			</div>
			<div class="shortcut-row">
				<span class="label">Strip précédent</span>
				<span class="keys"><span class="kbd">↑</span><span class="kbd">←</span></span>
			</div>
			<div class="shortcut-row">
				<span class="label">Thème clair / sombre</span>
				<span class="keys"><span class="kbd">T</span></span>
			</div>
			<div class="shortcut-row">
				<span class="label">Zoom panel</span>
				<span class="keys"><span class="kbd">Clic</span> sur panel</span>
			</div>
			<div class="shortcut-row">
				<span class="label">Fermer ce panneau</span>
				<span class="keys"><span class="kbd">?</span><span class="kbd">Échap</span></span>
			</div>
			<span class="shortcuts-close">Appuyez sur Échap ou ? pour fermer</span>
		</div>
	</div>

	<!-- Zoom overlay -->
	<div class="panel-zoom-overlay" id="zoomOverlay">
		<div class="zoomed-panel" id="zoomedContent"></div>
		<span class="zoom-hint">clic pour fermer</span>
	</div>

	<!-- Main reader -->
	<main class="reader" id="reader">
		<!-- Title screen -->
		<section class="title-screen" data-index="0" data-label="Titre">
			<span class="title-brand">Un webcomic par —</span>
			<h1 class="title-main">Le Concept<br>de la <em>Preuve</em></h1>
			<p class="title-sub">Huit strips pour tester le rythme, le scroll, et le silence entre les cases.</p>
			<div class="title-scroll-cue">
				<span>Défiler</span>
				<div class="scroll-arrow"></div>
			</div>
		</section>

		{sortedComics.map((comic, index) => (
			<EditorialCard
				comic={comic}
				index={index}
				total={sortedComics.length}
				eager={index === 0}
			/>
		))}
	</main>
</body>
</html>

<style is:global>
	/* ═══ THEME SYSTEM ═══ */
	:root {
		--font-display: 'Playfair Display', serif;
		--font-body: 'Cormorant Garamond', serif;
		--font-mono: 'Fira Code', 'Inconsolata', monospace;
		--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
		--ease-out-back: cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	[data-theme="dark"] {
		--bg: #08080a;
		--bg-elevated: #111114;
		--bg-panel: #18181c;
		--border: #252530;
		--border-hover: #3a3a48;
		--text: #ece8e1;
		--text-muted: #706e68;
		--text-dim: #4a4844;
		--accent: #e8532a;
		--accent-glow: rgba(232, 83, 42, 0.15);
		--panel-shadow: 0 4px 30px rgba(0,0,0,0.5);
		--vignette: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.4) 100%);
		--mask-top: linear-gradient(to bottom, transparent, var(--bg) 60px);
		--mask-bottom: linear-gradient(to top, transparent, var(--bg) 60px);
		--grain-opacity: 0.03;
	}

	[data-theme="light"] {
		--bg: #f5f2ec;
		--bg-elevated: #ffffff;
		--bg-panel: #ede9e2;
		--border: #d5d0c8;
		--border-hover: #b0a898;
		--text: #1a1816;
		--text-muted: #8a857c;
		--text-dim: #b5b0a8;
		--accent: #c43b1a;
		--accent-glow: rgba(196, 59, 26, 0.1);
		--panel-shadow: 0 4px 30px rgba(0,0,0,0.08);
		--vignette: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.06) 100%);
		--mask-top: linear-gradient(to bottom, transparent, var(--bg) 60px);
		--mask-bottom: linear-gradient(to top, transparent, var(--bg) 60px);
		--grain-opacity: 0.02;
	}

	/* ═══ RESET (scoped to this page) ═══ */
	html[data-theme] body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--font-body);
		font-size: 18px;
		line-height: 1.6;
		overflow: hidden;
		transition: background 0.5s ease, color 0.4s ease;
		-webkit-font-smoothing: antialiased;
	}

	/* Film grain overlay */
	html[data-theme] body::after {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 9999;
		opacity: var(--grain-opacity);
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
		background-repeat: repeat;
		background-size: 180px;
	}
</style>

<style>
	/* ═══ SCROLL CONTAINER ═══ */
	.reader {
		height: 100vh;
		width: 100vw;
		overflow-y: scroll;
		scroll-snap-type: y proximity;
		scrollbar-width: none;
		position: fixed;
		inset: 0;
		z-index: 10;
		background: var(--bg);
	}
	.reader::-webkit-scrollbar { display: none; }

	/* ═══ MIST EDGES ═══ */
	.mist-top, .mist-bottom {
		position: fixed;
		left: 0; right: 0;
		height: 80px;
		pointer-events: none;
		z-index: 60;
		transition: background 0.5s ease;
	}
	.mist-top    { top: 0; background: var(--mask-top); }
	.mist-bottom { bottom: 0; background: var(--mask-bottom); }

	/* ═══ PROGRESS BAR (CSS scroll-driven) ═══ */
	.progress {
		position: fixed;
		top: 0; left: 0;
		height: 2px;
		width: 100%;
		background: var(--accent);
		transform-origin: left;
		transform: scaleX(0);
		z-index: 100;
	}
	@supports (animation-timeline: scroll()) {
		.progress {
			animation: progress-grow linear;
			animation-timeline: scroll(nearest block);
		}
	}
	@keyframes progress-grow {
		from { transform: scaleX(0); }
		to   { transform: scaleX(1); }
	}

	/* ═══ TITLE SCREEN ═══ */
	.title-screen {
		height: 100vh;
		scroll-snap-align: center;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 3rem 2rem;
		position: relative;
	}
	.title-screen::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 500px 350px at 35% 45%, var(--accent-glow), transparent),
			var(--vignette);
		pointer-events: none;
	}
	.title-brand {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--accent);
		position: relative;
		opacity: 0;
		animation: fadeSlideUp 1s var(--ease-out-expo) 0.2s forwards;
	}
	.title-main {
		font-family: var(--font-display);
		font-size: clamp(2.8rem, 7vw, 5.5rem);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.8rem;
		position: relative;
		opacity: 0;
		animation: fadeSlideUp 1.2s var(--ease-out-expo) 0.5s forwards;
	}
	.title-main em {
		font-style: italic;
		font-weight: 400;
		font-family: var(--font-display);
	}
	.title-sub {
		font-family: var(--font-body);
		font-size: 1.1rem;
		font-style: italic;
		color: var(--text-muted);
		max-width: 380px;
		position: relative;
		opacity: 0;
		animation: fadeSlideUp 1s var(--ease-out-expo) 0.9s forwards;
	}
	.title-scroll-cue {
		position: absolute;
		bottom: 2.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		animation: fadeSlideUp 1s var(--ease-out-expo) 1.4s forwards;
	}
	.title-scroll-cue span {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-dim);
	}
	.scroll-arrow {
		width: 1px;
		height: 28px;
		background: linear-gradient(to bottom, var(--text-dim), transparent);
		position: relative;
		animation: arrowPulse 2.5s ease-in-out infinite;
	}
	.scroll-arrow::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		width: 6px;
		height: 6px;
		border-right: 1px solid var(--text-dim);
		border-bottom: 1px solid var(--text-dim);
		transform: translateX(-50%) rotate(45deg);
	}

	@keyframes fadeSlideUp {
		from { opacity: 0; transform: translateY(24px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes arrowPulse {
		0%, 100% { opacity: 0.4; transform: translateY(0); }
		50%      { opacity: 1;   transform: translateY(8px); }
	}

	/* ═══ NAV DOTS ═══ */
	.nav-rail {
		position: fixed;
		right: 1rem;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		z-index: 80;
	}
	@media (max-width: 640px) {
		.nav-rail { display: none; }
	}

	/* ═══ CONTROLS ═══ */
	.controls {
		position: fixed;
		top: 0; left: 0; right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 1.5rem;
		z-index: 90;
		pointer-events: none;
	}
	.controls > * { pointer-events: auto; }
	.controls .logo {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.3s;
	}
	.controls .logo:hover { color: var(--text); }
	.controls-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.ctrl-btn {
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 0.4rem 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 500;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.25s ease;
		display: flex;
		align-items: center;
		gap: 0.3rem;
		text-decoration: none;
	}
	.ctrl-btn:hover {
		border-color: var(--border-hover);
		color: var(--text);
	}
	.ctrl-btn svg {
		width: 14px; height: 14px;
		stroke: currentColor;
		fill: none;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	/* ═══ RIPPLE ═══ */
	.ripple {
		position: fixed;
		width: 60px; height: 60px;
		border-radius: 50%;
		background: var(--accent);
		opacity: 0;
		transform: scale(0);
		pointer-events: none;
		z-index: 50;
	}

	/* ═══ ZOOM OVERLAY ═══ */
	.panel-zoom-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.85);
		z-index: 200;
		justify-content: center;
		align-items: center;
		cursor: zoom-out;
	}
	.panel-zoom-overlay.active { display: flex; }
	.zoomed-panel {
		width: min(90vw, 700px);
		max-height: 85vh;
		overflow: hidden;
		border-radius: 6px;
		animation: zoomIn 0.3s var(--ease-out-expo);
	}
	.zoom-hint {
		position: absolute;
		bottom: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--text-dim);
		letter-spacing: 0.1em;
	}
	@keyframes zoomIn {
		from { opacity: 0; transform: scale(0.9); }
		to   { opacity: 1; transform: scale(1); }
	}

	/* ═══ SHORTCUTS OVERLAY ═══ */
	.shortcuts-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.8);
		backdrop-filter: blur(8px);
		z-index: 300;
		justify-content: center;
		align-items: center;
	}
	.shortcuts-overlay.active { display: flex; }
	.shortcuts-box {
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2.5rem;
		max-width: 420px;
		width: 90%;
		animation: zoomIn 0.3s var(--ease-out-expo);
	}
	.shortcuts-box h3 {
		font-family: var(--font-display);
		font-size: 1.4rem;
		margin-bottom: 1.5rem;
	}
	.shortcut-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--border);
	}
	.shortcut-row:last-child { border: none; }
	.shortcut-row .label {
		font-family: var(--font-body);
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.shortcut-row .keys {
		display: flex;
		gap: 0.3rem;
	}
	.kbd {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		background: var(--bg-panel);
		border: 1px solid var(--border);
		border-radius: 4px;
		padding: 0.2rem 0.5rem;
		color: var(--text-muted);
	}
	.shortcuts-close {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--text-dim);
		margin-top: 1.5rem;
		text-align: center;
		display: block;
	}

	/* ═══ BOTTOM HINT & COUNTER ═══ */
	.hint-bar {
		position: fixed;
		bottom: 1rem;
		left: 50%;
		transform: translateX(-50%);
		font-family: var(--font-mono);
		font-size: 0.55rem;
		letter-spacing: 0.15em;
		color: var(--text-dim);
		z-index: 80;
		transition: opacity 0.6s ease;
		text-transform: uppercase;
		white-space: nowrap;
	}
	.hint-bar.hidden { opacity: 0; pointer-events: none; }

	.strip-counter {
		position: fixed;
		bottom: 1rem;
		right: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--text-dim);
		letter-spacing: 0.1em;
		z-index: 80;
	}

	@media (max-width: 640px) {
		.controls { padding: 0.8rem 1rem; }
		.strip-counter { display: none; }
	}

	@media (prefers-reduced-motion: reduce) {
		.title-brand, .title-main, .title-sub, .title-scroll-cue {
			animation: none;
			opacity: 1;
		}
		.reader {
			scroll-snap-type: none;
		}
	}
</style>

<script>
	(() => {
		'use strict';

		const reader = document.getElementById('reader')!;
		const sections = [...document.querySelectorAll<HTMLElement>('[data-index]')];
		const progressBar = document.getElementById('progress')!;
		const navRail = document.getElementById('navRail')!;
		const hintBar = document.getElementById('hintBar')!;
		const stripCounter = document.getElementById('stripCounter')!;
		const ripple = document.getElementById('ripple')!;
		const themeToggle = document.getElementById('themeToggle')!;
		const themeIcon = document.getElementById('themeIcon')!;
		const shortcutsBtn = document.getElementById('shortcutsBtn')!;
		const shortcutsOverlay = document.getElementById('shortcutsOverlay')!;
		const zoomOverlay = document.getElementById('zoomOverlay')!;
		const zoomedContent = document.getElementById('zoomedContent')!;

		let currentIndex = 0;
		let interactions = 0;
		const totalStrips = sections.length;

		const hasScrollDriven = CSS.supports('animation-timeline', 'view()');

		// ─── Build nav dots ───
		sections.forEach((s, i) => {
			const dot = document.createElement('button');
			dot.className = 'ed-nav-dot';
			dot.dataset.label = s.dataset.label || '';
			dot.setAttribute('aria-label', `Aller à ${s.dataset.label || 'section ' + i}`);
			dot.addEventListener('click', (e) => { e.stopPropagation(); scrollToIndex(i); });
			navRail.appendChild(dot);
		});
		const dots = [...navRail.querySelectorAll<HTMLElement>('.ed-nav-dot')];

		// Inject dot styles
		const dotStyles = document.createElement('style');
		dotStyles.textContent = `
			.ed-nav-dot {
				width: 4px; height: 4px; border-radius: 50%;
				background: var(--text-dim); border: none; padding: 0;
				cursor: pointer; transition: all 0.35s var(--ease-out-expo);
				position: relative;
			}
			.ed-nav-dot:hover { background: var(--text-muted); transform: scale(2); }
			.ed-nav-dot.active { background: var(--accent); transform: scale(2.2); box-shadow: 0 0 8px var(--accent-glow); }
			.ed-nav-dot::before {
				content: attr(data-label);
				position: absolute; right: calc(100% + 12px); top: 50%; transform: translateY(-50%);
				font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.08em;
				color: var(--text-muted); white-space: nowrap; opacity: 0;
				transition: opacity 0.2s ease; pointer-events: none;
			}
			.ed-nav-dot:hover::before { opacity: 1; }
			.ripple.active { animation: rippleAnim 0.6s var(--ease-out-expo); }
			@keyframes rippleAnim {
				0%   { opacity: 0.2; transform: scale(0); }
				100% { opacity: 0; transform: scale(3); }
			}
		`;
		document.head.appendChild(dotStyles);

		// ─── Theme ───
		const savedTheme = localStorage.getItem('lcdlp-theme') ||
			(window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
		setTheme(savedTheme);

		function setTheme(t: string) {
			document.documentElement.dataset.theme = t;
			localStorage.setItem('lcdlp-theme', t);
			themeIcon.innerHTML = t === 'dark'
				? '<path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>'
				: '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
		}

		themeToggle.addEventListener('click', (e) => {
			e.stopPropagation();
			const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
			setTheme(next);
		});

		// ─── Navigation ───
		function scrollToIndex(i: number) {
			const clamped = Math.max(0, Math.min(i, totalStrips - 1));
			sections[clamped].scrollIntoView({ behavior: 'smooth', block: 'center' });
			currentIndex = clamped;
			updateUI();
		}

		function updateUI() {
			dots.forEach((d, i) => d.classList.toggle('active', i === currentIndex));
			stripCounter.textContent = currentIndex === 0
				? '— / —'
				: `${String(currentIndex).padStart(2, '0')} / ${String(totalStrips - 1).padStart(2, '0')}`;
			interactions++;
			if (interactions > 3) hintBar.classList.add('hidden');
		}

		// ─── Progress bar fallback ───
		if (!hasScrollDriven) {
			reader.addEventListener('scroll', () => {
				const pct = reader.scrollTop / (reader.scrollHeight - reader.clientHeight);
				progressBar.style.transform = `scaleX(${pct})`;
			}, { passive: true });
		}

		// ─── IntersectionObserver fallback for reveal ───
		const observer = new IntersectionObserver((entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					const idx = parseInt((entry.target as HTMLElement).dataset.index ?? '', 10);
					if (!isNaN(idx)) {
						currentIndex = idx;
						updateUI();
					}
				}
			}
		}, { root: reader, threshold: 0.35 });

		sections.forEach((s) => observer.observe(s));

		// ─── Keyboard ───
		document.addEventListener('keydown', (e) => {
			if (e.key === '?' || (e.key === '/' && e.shiftKey)) {
				e.preventDefault();
				shortcutsOverlay.classList.toggle('active');
				return;
			}
			if (e.key === 'Escape') {
				shortcutsOverlay.classList.remove('active');
				zoomOverlay.classList.remove('active');
				return;
			}
			if ((e.key === 't' || e.key === 'T') && !shortcutsOverlay.classList.contains('active')) {
				setTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
				return;
			}

			const next = ['ArrowDown', 'ArrowRight', ' '];
			const prev = ['ArrowUp', 'ArrowLeft'];
			if (next.includes(e.key)) { e.preventDefault(); scrollToIndex(currentIndex + 1); }
			else if (prev.includes(e.key)) { e.preventDefault(); scrollToIndex(currentIndex - 1); }
		});

		// ─── Shortcuts button ───
		shortcutsBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			shortcutsOverlay.classList.toggle('active');
		});
		shortcutsOverlay.addEventListener('click', (e) => {
			if (e.target === shortcutsOverlay) shortcutsOverlay.classList.remove('active');
		});

		// ─── Tap / click navigation with ripple ───
		function spawnRipple(x: number, y: number) {
			ripple.style.left = `${x - 30}px`;
			ripple.style.top = `${y - 30}px`;
			ripple.classList.remove('active');
			void ripple.offsetWidth;
			ripple.classList.add('active');
		}

		reader.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (target.closest('.controls') || target.closest('.nav-rail') ||
				target.closest('button') || target.closest('a') ||
				target.closest('[data-p]')) return;

			spawnRipple(e.clientX, e.clientY);
			scrollToIndex(e.clientX > window.innerWidth / 2 ? currentIndex + 1 : currentIndex - 1);
		});

		// ─── Panel zoom ───
		document.querySelectorAll('[data-p]').forEach((panel) => {
			panel.addEventListener('click', (e) => {
				e.stopPropagation();
				// Clone the panel's image into the zoom overlay
				const img = panel.querySelector('img');
				if (img) {
					zoomedContent.innerHTML = '';
					const cloned = img.cloneNode(true) as HTMLImageElement;
					cloned.style.width = '100%';
					cloned.style.height = 'auto';
					cloned.style.display = 'block';
					zoomedContent.appendChild(cloned);
				}
				zoomOverlay.classList.add('active');
			});
		});
		zoomOverlay.addEventListener('click', () => {
			zoomOverlay.classList.remove('active');
		});

		// ─── Mobile swipe indicator sync ───
		document.querySelectorAll('.panels').forEach((container) => {
			const swipeDots = [...(container.parentElement?.querySelectorAll('.swipe-dot') ?? [])];
			if (!swipeDots.length) return;

			container.addEventListener('scroll', () => {
				const scrollLeft = container.scrollLeft;
				const panelWidth = (container.children[0] as HTMLElement)?.offsetWidth || 1;
				const gap = parseFloat(getComputedStyle(container).gap) || 0;
				const idx = Math.round(scrollLeft / (panelWidth + gap));
				swipeDots.forEach((d, i) => d.classList.toggle('active', i === idx));
			}, { passive: true });
		});

		// ─── Init ───
		updateUI();
	})();
</script>
